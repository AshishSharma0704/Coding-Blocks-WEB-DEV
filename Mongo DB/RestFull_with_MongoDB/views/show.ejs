<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= product.name %></title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body{
            background:#f5f5f5;
        }

        .product-card{
            max-width:900px;
            margin:60px auto;
            background:#fff;
            border-radius:15px;
            overflow:hidden;
            box-shadow:0 10px 25px rgba(0,0,0,.15);
        }

        .product-img{
            width:100%;
            height:500px;
            object-fit:cover;
        }

        .product-content{
            padding:30px;
        }

        .product-title{
            font-size:2.2rem;
            font-weight:bold;
            margin-bottom:15px;
        }

        .price{
            color:#198754;
            font-size:1.8rem;
            font-weight:bold;
            margin-bottom:20px;
        }

        .description{
            font-size:1.1rem;
            color:#555;
            line-height:1.8;
        }

        .btn-custom{
            margin-top:30px;
            margin-right:10px;
        }
    </style>

</head>

<body>

<div class="container">

    <div class="card product-card">

        <div class="row g-0">

            <div class="col-md-6">
                <img src="<%= product.image %>" class="product-img">
            </div>

            <div class="col-md-6">

                <div class="product-content">

                    <h1 class="product-title">
                        <%= product.name %>
                    </h1>

                    <h2 class="price">
                        ₹ <%= product.price %>
                    </h2>

                    <p class="description">
                        <%= product.description %>
                    </p>

                    <a href="/products" class="btn btn-primary btn-custom">
                        ← Back
                    </a>

                    <a href="/products/<%= product._id %>/edit" class="btn btn-warning btn-custom">
                        Edit
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

</body>
</html>