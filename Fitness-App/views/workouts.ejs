<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Workout Tracker | Fitness Challenge Community</title>
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/workouts.css">
    

    <style>
        
    </style>

</head>
<body>

<%- include("partials/navbar") %>

<div class="container">

    <div class="title">
        <h1>Workout Tracker</h1>
        <p>Log today's workout and monitor your progress.</p>
    </div>

    <div class="content">

        <!-- Workout Form -->

        <div class="card top-bar">

        <div>
            <h2>Workout History</h2>
            <p>Track every workout and monitor your fitness progress.</p>
        </div>

        <a href="/workouts/add" class="btn">
            ➕ Add Workout
        </a>

    </div>

        <!-- Workout Table -->

        <div class="card">

            <h2>Workout History</h2>

            <table>

                <tr>
                    <th>Exercise</th>
                    <th>Category</th>
                    <th>Sets</th>
                    <th>Reps</th>
                    <th>Weight</th>
                    <th>Duration</th>
                    <th>Calories</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>

                <% if(workouts.length===0){ %>

                    <tr>
                        <td colspan="5">No workouts added yet.</td>
                    </tr>

                <% } %>

                <% workouts.forEach(workout=>{ %>

                    <tr>

                        <td><%= workout.exercise %></td>
                        <td><%= workout.category %></td>
                        <td><%= workout.sets %></td>
                        <td><%= workout.reps %></td>
                        <td><%= workout.weight %> kg</td>
                        <td><%= workout.duration %> min</td>
                        <td><%= workout.caloriesBurned %></td>
                        <td><%= workout.workoutDate.toLocaleDateString() %></td>

                        <td>

                            <a class="edit" href="/workouts/edit/<%= workout._id %>">
                                Edit
                            </a>

                            <a
                                class="delete"
                                href="/workouts/delete/<%= workout._id %>"
                                onclick="return confirm('Are you sure you want to delete this workout?')"
                            >
                                Delete
                            </a>

                        </td>

                    </tr>

                <% }) %>

            </table>

        </div>

    </div>

</div>

<footer>

    <p>© 2026 Fitness Challenge Community</p>

</footer>

</body>
</html>