<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Workout Tracker | Fitness Challenge Community</title>

    <link rel="stylesheet" href="/css/workouts.css">

    <style>
        
    </style>

</head>
<body>

<nav>
    <h2>Fitness Community</h2>

    <ul>
        <li><a href="/dashboard">Dashboard</a></li>
        <li><a href="/workouts">Workouts</a></li>
        <li><a href="/challenges">Challenges</a></li>
        <li><a href="/leaderboard">Leaderboard</a></li>
        <li><a href="/profile">Profile</a></li>
    </ul>
</nav>

<div class="container">

    <div class="title">
        <h1>Workout Tracker</h1>
        <p>Log today's workout and monitor your progress.</p>
    </div>

    <div class="content">

        <!-- Workout Form -->

        <div class="card">

            <h2>Add Workout</h2>

            <form action="/workouts" method="POST">

                <div class="form-group">
                    <label>Exercise Name</label>
                    <input type="text" name="exercise" required>
                </div>

                <div class="form-group">
                    <label>Category</label>

                    <select name="category">
                        <option>Strength</option>
                        <option>Cardio</option>
                        <option>Yoga</option>
                        <option>HIIT</option>
                    </select>

                </div>

                <div class="form-group">
                    <label>Sets</label>
                    <input type="number" name="sets">
                </div>

                <div class="form-group">
                    <label>Reps</label>
                    <input type="number" name="reps">
                </div>

                <div class="form-group">
                    <label>Weight (kg)</label>
                    <input type="number" name="weight">
                </div>

                <div class="form-group">
                    <label>Duration (minutes)</label>
                    <input type="number" name="duration">
                </div>

                <div class="form-group">
                    <label>Calories Burned</label>
                    <input type="number" name="calories">
                </div>

                <button>Add Workout</button>

            </form>

        </div>

        <!-- Workout Table -->

        <div class="card">

            <h2>Workout History</h2>

            <table>

                <tr>
                    <th>Exercise</th>
                    <th>Category</th>
                    <th>Duration</th>
                    <th>Calories</th>
                    <th>Actions</th>
                </tr>

                <% if(workouts.length===0){ %>

                    <tr>
                        <td colspan="5">No workouts added yet.</td>
                    </tr>

                <% } %>

                <% workouts.forEach(workout=>{ %>

                    <tr>

                        <td><%= workout.exercise %></td>

                        <td><%= workout.category %></td>

                        <td><%= workout.duration %> min</td>

                        <td><%= workout.calories %></td>

                        <td>

                            <a class="edit" href="/workouts/edit/<%= workout._id %>">
                                Edit
                            </a>

                            <a class="delete" href="/workouts/delete/<%= workout._id %>">
                                Delete
                            </a>

                        </td>

                    </tr>

                <% }) %>

            </table>

        </div>

    </div>

</div>

<footer>

    <p>© 2026 Fitness Challenge Community</p>

</footer>

</body>
</html>