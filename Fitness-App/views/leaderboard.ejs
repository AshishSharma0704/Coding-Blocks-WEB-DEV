<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Leaderboard</title>
    <link rel="stylesheet" href="/css/theme.css">
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/leaderboard.css">
</head>
<body>

<%- include("partials/navbar") %>

<div class="leaderboard-container">

    <div class="leaderboard-header">
        <h1>Leaderboard</h1>
        <p>Top Fitness Champions</p>
    </div>

    <% if(users.length >= 3){ %>

    <div class="top-three">

        <div class="winner second">
            <div class="medal">🥈</div>
            <h3><%= users[1].name %></h3>
            <p><%= users[1].points%> pts</p>
        </div>

        <div class="winner first">
            <div class="medal">🥇</div>
            <h2><%= users[0].name %></h2>
            <p><%= users[0].points%> pts</p>
        </div>

        <div class="winner third">
            <div class="medal">🥉</div>
            <h3><%= users[2].name %></h3>
            <p><%= users[2].points%> pts</p>
        </div>

    </div>

    <% } %>

    <div class="ranking-list">

        <h2>All Rankings</h2>

        <% users.forEach((user,index)=>{ %>

            <div class="rank-card <%= user._id.toString()===currentUserId ? 'current-user' : '' %>">

                <div class="rank">

                    #<%= index+1 %>

                </div>

                <div class="user-info">

                    <h3><%= user.name %></h3>

                    <p><%= user.email %></p>

                </div>

                <div class="points">

                    <%= user.points%> pts

                </div>

            </div>

        <% }) %>

    </div>

    <div class="your-rank">

        <h2>Your Rank</h2>

        <h1>#<%= currentRank %></h1>

        <p>
            <%= users.find(user => user._id.toString() === currentUserId)?.points|| 0 %> Points
        </p>

        <span>Keep Going 💪</span>

    </div>

</div>

</body>
</html>