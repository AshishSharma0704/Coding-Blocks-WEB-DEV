<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fitness Challenge Community</title>

    <link rel="stylesheet" href="/css/theme.css">
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/index.css">
</head>
<body>

<%- include("partials/navbar") %>


<section class="hero">

    <div class="container hero-wrapper">

        <div class="hero-content">

            <span class="tag">
                🏋 Fitness Challenge Community
            </span>

            <h1>
                Transform Your
                <span>Fitness</span>
                Journey Together
            </h1>

            <p>
                Build healthy habits with your community.
                Track workouts, compete in challenges,
                earn rewards and stay motivated every day.
            </p>

            <div class="hero-buttons">

                <a href="/register" class="btn">
                    Get Started
                </a>

                <a href="/challenges" class="btn btn-outline">
                    Explore Challenges
                </a>

            </div>

            <div class="hero-stats">

                <div class="glass-card hero-stat">
                    <h2>5K+</h2>
                    <span>Members</span>
                </div>

                <div class="glass-card hero-stat">
                    <h2>150+</h2>
                    <span>Challenges</span>
                </div>

                <div class="glass-card hero-stat">
                    <h2>12K+</h2>
                    <span>Workouts</span>
                </div>

                <div class="glass-card hero-stat">
                    <h2>98%</h2>
                    <span>Success Rate</span>
                </div>

            </div>

        </div>

        <div class="hero-image">
            <video
                autoplay
                muted
                loop
                playsinline
                preload="auto"
            >
                <source src="/images/hero.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>

    </div>

</section>


<section>

    <div class="container">

        <div class="section-title">

            <h2>Everything You Need</h2>

            <p>
                Everything required to build consistency
                and achieve your fitness goals.
            </p>

        </div>

        <div class="feature-grid">

            <div class="glass-card feature-card">

                

                <h3>Workout Tracking</h3>

                <p>
                    Record workouts, calories,
                    duration and personal records.
                </p>

            </div>

            <div class="glass-card feature-card">


                <h3>Challenges</h3>

                <p>
                    Join exciting monthly and weekly
                    fitness competitions.
                </p>

            </div>

            <div class="glass-card feature-card">


                <h3>Progress Analytics</h3>

                <p>
                    Visualize your fitness journey
                    with charts and statistics.
                </p>

            </div>

            <div class="glass-card feature-card">


                <h3>Community</h3>

                <p>
                    Compete with friends,
                    climb the leaderboard
                    and stay motivated.
                </p>

            </div>

        </div>

    </div>

</section>


<section>

    <div class="container">

        <div class="section-title">

            <h2>How It Works</h2>

        </div>

        <div class="steps">

            <div class="glass-card step">

                <div class="step-number">1</div>

                <h3>Create Account</h3>

                <p>Register in less than one minute.</p>

            </div>

            <div class="glass-card step">

                <div class="step-number">2</div>

                <h3>Join Challenge</h3>

                <p>Select challenges that match your goals.</p>

            </div>

            <div class="glass-card step">

                <div class="step-number">3</div>

                <h3>Track Progress</h3>

                <p>Log every workout and improve daily.</p>

            </div>

            <div class="glass-card step">

                <div class="step-number">4</div>

                <h3>Earn Rewards</h3>

                <p>Unlock badges and climb the leaderboard.</p>

            </div>

        </div>

    </div>

</section>


<section>

    <div class="container">

        <div class="section-title">

            <h2>Community Stories</h2>

        </div>

        <div class="testimonials">

            <div class="glass-card testimonial">

                <p>
                    ⭐⭐⭐⭐⭐
                </p>

                <p>
                    "This community helped me stay
                    consistent for over 100 days."
                </p>

                <h4>Rahul Sharma</h4>

            </div>

            <div class="glass-card testimonial">

                <p>
                    ⭐⭐⭐⭐⭐
                </p>

                <p>
                    "The challenges make working out
                    genuinely fun and motivating."
                </p>

                <h4>Priya Patel</h4>

            </div>

            <div class="glass-card testimonial">

                <p>
                    ⭐⭐⭐⭐⭐
                </p>

                <p>
                    "Tracking progress visually keeps
                    me focused every single day."
                </p>

                <h4>Arjun Mehta</h4>

            </div>

        </div>

    </div>

</section>


<section class="cta">

    <div class="container">

        <div class="glass-card cta-box">

            <h2>
                Ready To Transform Your Lifestyle?
            </h2>

            <p>
                Join thousands of fitness enthusiasts
                building stronger habits together.
            </p>

            <a href="/register" class="btn">
                Start Your Journey
            </a>

        </div>

    </div>

</section>

<footer>

    <p>
        © 2026 Fitness Challenge Community.
        All Rights Reserved.
    </p>

</footer>


</body>
</html>