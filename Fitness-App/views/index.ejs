<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fitness Challenge Community</title>
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/index.css">
    
</head>
<body>

<%- include("partials/navbar") %>



<section class="hero">

    <div class="hero-content animate-hero">

        <h1>
            Transform Your <br>
            Fitness Journey
        </h1>

        <p>

            Track workouts, compete in exciting fitness challenges,
            upload progress photos, earn rewards,
            and stay motivated with an active community.

        </p>

        <div class="hero-buttons">

            <a href="/register" class="btn primary">
                Get Started
            </a>

            <a href="/login" class="btn secondary">
                Login
            </a>

        </div>


        <div class="hero-stats">

            <div>

                <h2>10K+</h2>

                <span>Members</span>

            </div>

            <div>

                <h2>50K+</h2>

                <span>Workouts</span>

            </div>

            <div>

                <h2>300+</h2>

                <span>Challenges</span>

            </div>

        </div>

    </div>

</section>


<section class="features">

    <h2>Everything You Need To Stay Fit</h2>

    <div class="cards">

        <div class="card">

            <h3>Workout Tracker</h3>

            <p>

                Record exercises, sets, reps,
                weight, duration and calories burned.

            </p>

        </div>

        <div class="card">

            <h3>Challenges</h3>

            <p>

                Join public challenges or create your own
                and compete with friends.

            </p>

        </div>

        <div class="card">

            <h3>Leaderboard</h3>

            <p>

                Earn points and climb the rankings by staying active.

            </p>

        </div>

        <div class="card">

            <h3>Progress Photos</h3>

            <p>

                Upload before & after photos
                and track your transformation.

            </p>

        </div>

        <div class="card">

            <h3>Daily Streak</h3>

            <p>

                Build consistency by maintaining
                your daily workout streak.

            </p>

        </div>

        <div class="card">

            <h3>Fitness Community</h3>

            <p>

                Connect with friends,
                motivate each other,
                and celebrate achievements.

            </p>

        </div>

    </div>

</section>


<section class="cta">

    <h2>

        Ready To Become A Better Version Of Yourself?

    </h2>

    <p>

        Join thousands of fitness enthusiasts
        who are already transforming their lives.

    </p>

    <a href="/register" class="btn primary">

        Join Now

    </a>

</section>


<footer>

    <p>

        <!-- © 2026 Fitness Challenge Community -->

    </p>

    <p>

        <!-- Built with ❤️ using Node.js, Express, MongoDB & EJS -->

    </p>

</footer>

</body>
</html>