<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>My Profile | Fitness Challenge Community</title>
<link rel="stylesheet" href="/css/theme.css">
<link rel="stylesheet" href="/css/common.css">
<link rel="stylesheet" href="/css/profile.css">
</head>
<body>

<%- include("partials/navbar") %>

<div class="profile-header">
  <div class="cover"></div>
  <div class="profile-content container">
    <div class="avatar"><%= user.name.charAt(0).toUpperCase() %></div>
    <div class="profile-info">
      <h1><%= user.name %></h1>
      <p><%= user.email %></p>
      <div class="mini-info">
        <span>🎂 <%= user.age %> Years</span>
        <span>📏 <%= user.height %> cm</span>
        <span>⚖️ <%= user.weight %> kg</span>
        <span>❤️ BMI <%= user.bmi %></span>
      </div>
    </div>
    <a href="/profile/edit" class="btn">Edit Profile</a>
  </div>
</div>

<div class="container">

<div class="stats-grid">
  <div class="stat-card"><h2><%= totalWorkouts %></h2><p>Workouts</p></div>
  <div class="stat-card"><h2><%= user.points %></h2><p>Points</p></div>
  <div class="stat-card"><h2><%= user.streak %></h2><p>Streak</p></div>
  <div class="stat-card"><h2><%= totalChallenges %></h2><p>Challenges</p></div>
</div>

<div class="goal-card">
<h3>Weekly Goal</h3>
<div class="progress"><div class="progress-fill" style="width:<%= Math.min((totalWorkouts/10)*100,100) %>%"></div></div>
<p><%= totalWorkouts %>/10 Workouts Completed</p>
</div>

<div class="profile-layout">

<div class="left-panel">

<div class="card">
<h3>Personal Information</h3>
<ul class="info-list">
<li><strong>Age</strong><span><%= user.age %></span></li>
<li><strong>Height</strong><span><%= user.height %> cm</span></li>
<li><strong>Weight</strong><span><%= user.weight %> kg</span></li>
<li><strong>BMI</strong><span><%= user.bmi %></span></li>
</ul>
</div>

<div class="card">
<h3>Achievements</h3>
<div class="badges">
<span>🔥 7 Day Streak</span>
<span>💪 100 Workouts</span>
<span>🏆 Top Performer</span>
<span>🎯 Challenge Winner</span>
</div>
</div>

</div>

<div class="right-panel">

<div class="card">
<h3>Recent Workouts</h3>
<table>
<thead>
<tr>
<th>Exercise</th>
<th>Category</th>
<th>Duration</th>
<th>Calories</th>
<th>Date</th>
</tr>
</thead>
<tbody>
<% if(workouts.length){ %>
<% workouts.forEach(workout=>{ %>
<tr>
<td><%= workout.exercise %></td>
<td><%= workout.category %></td>
<td><%= workout.duration %> min</td>
<td><%= workout.caloriesBurned %></td>
<td><%= workout.workoutDate.toLocaleDateString() %></td>
</tr>
<% }) %>
<% } else { %>
<tr><td colspan="5">No workouts yet.</td></tr>
<% } %>
</tbody>
</table>
</div>

<div class="card">
<h3>Recent Activity</h3>
<div class="timeline">
<% workouts.slice(0,5).forEach(workout=>{ %>
<div class="timeline-item">
<div class="dot"></div>
<div>
<strong><%= workout.exercise %></strong><br>
<small><%= workout.workoutDate.toLocaleDateString() %></small>
</div>
</div>
<% }) %>
</div>
</div>

</div>

</div>

</div>

<footer>
<p>© 2026 Fitness Challenge Community</p>
</footer>

</body>
</html>