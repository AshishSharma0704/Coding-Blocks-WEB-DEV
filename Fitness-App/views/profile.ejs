<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Profile | Fitness Challenge Community</title>

    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/common.css">
</head>
<body>

<%- include("partials/navbar") %>

<div class="container">

    <!-- Profile -->

    <div class="profile-card">

        <img
            src="https://via.placeholder.com/150"
            class="profile-image"
            alt="Profile">

        <div class="info">

            <h1><%= user.name %></h1>

            <p><strong>Email:</strong> <%= user.email %></p>

            <p><strong>Age:</strong> <%= user.age %></p>

            <p><strong>Height:</strong> <%= user.height %> cm</p>

            <p><strong>Weight:</strong> <%= user.weight %> kg</p>

            <p><strong>BMI:</strong> <%= user.bmi %></p>

            <a href="/profile/edit" class="btn">
                Edit Profile
            </a>

        </div>

    </div>

    <!-- Statistics -->

    <div class="stats">

        <div class="card">
            <h2><%= user.totalWorkouts %></h2>
            <p>Total Workouts</p>
        </div>

        <div class="card">
            <h2><%= user.points %></h2>
            <p>Challenge Points</p>
        </div>

        <div class="card">
            <h2><%= user.streak %></h2>
            <p>Current Streak</p>
        </div>

        <div class="card">
            <h2><%= user.challenges %></h2>
            <p>Challenges Joined</p>
        </div>

    </div>

    <!-- Recent Workouts -->

    <div class="section">

        <h2>Recent Workouts</h2>

        <table>

            <tr>

                <th>Exercise</th>

                <th>Duration</th>

                <th>Calories</th>

            </tr>

            <% workouts.forEach(workout=>{ %>

            <tr>

                <td><%= workout.exercise %></td>

                <td><%= workout.duration %> min</td>

                <td><%= workout.calories %></td>

            </tr>

            <% }) %>

        </table>

    </div>

    <!-- Achievements -->

    <div class="section">

        <h2>Achievements</h2>

        <div class="badges">

            <div class="badge">🔥 7-Day Streak</div>

            <div class="badge">🏆 Top 10 Leaderboard</div>

            <div class="badge">💪 100 Workouts</div>

            <div class="badge">🎯 Challenge Winner</div>

        </div>

    </div>

</div>

<footer>

    <p>© 2026 Fitness Challenge Community</p>

</footer>

</body>
</html>