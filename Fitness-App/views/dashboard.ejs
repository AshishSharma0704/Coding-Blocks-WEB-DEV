<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Fitness Challenge Community</title>
    <link rel="stylesheet" href="/css/theme.css">
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/dashboard.css">
</head>

<body>

<%- include("partials/navbar") %>

<div class="dashboard">

    <!-- HERO -->

    <section class="hero">

        <div class="hero-text">

            <h1>👋 Welcome, <%= user.name %></h1>

            <p>
                Stay consistent! Every workout brings you closer to your fitness goal.
            </p>

        </div>

        <div class="hero-goal">

            <h3>Weekly Goal</h3>

            <p><%= totalWorkouts %> / 7 Workouts</p>

            <div class="progress">

                <div
                    class="progress-fill"
                    style="--progress:<%= progressPercentage %>%;">
                </div>

            </div>

            <span>

                <%= Math.min(Math.round((totalWorkouts/7)*100),100) %>% Complete

            </span>

        </div>

    </section>


    <!-- STATS -->

    <section class="stats">

        <div class="stat-card">
            <h4>🏋 Total Workouts</h4>
            <h2><%= totalWorkouts %></h2>
        </div>

        <div class="stat-card">
            <h4>🔥 Calories Burned</h4>
            <h2><%= totalCalories %></h2>
        </div>

        <div class="stat-card">
            <h4>⏱ Workout Minutes</h4>
            <h2><%= totalDuration %></h2>
        </div>

        <div class="stat-card">
            <h4>🔥 Current Streak</h4>
            <h2><%= user.streak %> Days</h2>
        </div>

    </section>


    <div class="dashboard-grid">

        <!-- LEFT PANEL -->

        <div class="left-panel">

            <!-- RECENT WORKOUTS -->

            <div class="card">

                <div class="card-header">

                    <h2>🏋 Recent Workouts</h2>

                    <a href="/workouts">View All</a>

                </div>

                <% if(recentWorkouts.length===0){ %>

                    <div class="empty">

                        <p>No workouts logged yet.</p>

                        <a href="/workouts/add" class="btn">

                            Add Your First Workout

                        </a>

                    </div>

                <% } else { %>

                    <table class="recent-table">

                        <thead>

                            <tr>

                                <th>Exercise</th>
                                <th>Category</th>
                                <th>Duration</th>
                                <th>Calories</th>

                            </tr>

                        </thead>

                        <tbody>

                        <% recentWorkouts.forEach(workout=>{ %>

                            <tr>

                                <td>

                                    <strong><%= workout.exercise %></strong>

                                </td>

                                <td>

                                    <%= workout.category %>

                                </td>

                                <td>

                                    <%= workout.duration %> min

                                </td>

                                <td>

                                    <%= workout.caloriesBurned %>

                                </td>

                            </tr>

                        <% }) %>

                        </tbody>

                    </table>

                <% } %>

            </div>


            <!-- FITNESS SUMMARY -->

            <div class="card">

                <h2>📊 Fitness Summary</h2>

                <div class="summary">

                    <div>

                        <h3>Total Sessions</h3>

                        <p><%= totalWorkouts %></p>

                    </div>

                    <div>

                        <h3>Total Duration</h3>

                        <p><%= totalDuration %> mins</p>

                    </div>

                    <div>

                        <h3>Total Calories</h3>

                        <p><%= totalCalories %></p>

                    </div>

                    <div>

                        <h3>Current Weight</h3>

                        <p><%= user.weight %> kg</p>

                    </div>

                </div>

            </div>

        </div>


        <!-- RIGHT PANEL -->

        <div class="right-panel">

            <!-- PROFILE -->

            <div class="card">

                <h2>👤 Profile</h2>

                <hr>

                <p><strong>Name</strong></p>
                <p><%= user.name %></p>

                <p><strong>Email</strong></p>
                <p><%= user.email %></p>

                <p><strong>Age</strong></p>
                <p><%= user.age %> Years</p>

                <p><strong>Height</strong></p>
                <p><%= user.height %> cm</p>

                <p><strong>Weight</strong></p>
                <p><%= user.weight %> kg</p>

            </div>


            <!-- UPCOMING FEATURES -->

            <div class="card">

                <h2>🚀 Coming Soon</h2>

                <ul>

                    <li>🏆 Fitness Challenges</li>

                    <li>🥇 Live Leaderboard</li>

                    <li>📷 Progress Photos</li>

                    <li>👥 Community Feed</li>

                    <li>📈 Workout Charts</li>

                </ul>

            </div>


            <!-- QUICK ACTIONS -->

            <div class="card">

                <h2>⚡ Quick Actions</h2>

                <div class="quick-actions">

                    <a href="/workouts/add" class="action-btn">

                        ➕ Add Workout

                    </a>

                    <a href="/workouts" class="action-btn">

                        🏋 My Workouts

                    </a>

                    <a href="/profile" class="action-btn">

                        👤 Edit Profile

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<footer>

    <p>© 2026 Fitness Challenge Community</p>

</footer>

</body>

</html>
