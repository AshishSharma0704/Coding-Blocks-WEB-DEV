<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Fitness Challenge Community</title>
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/dashboard.css">
    
</head>

<body>

<%- include("partials/navbar") %>

<div class="dashboard">

    <!-- ================= HERO ================= -->

    <section class="hero">

        <div class="hero-text">

            <h1>Welcome, <%= user.name %> 👋</h1>

            <p>
                Keep pushing yourself! You're one workout closer to
                achieving your weekly fitness goal.
            </p>

        </div>

        <div class="hero-goal">

            <h3>Weekly Goal</h3>

            <p>4 of 7 Workouts Completed</p>

            <div class="progress">

                <div class="progress-fill"></div>

            </div>

            <span>57% Complete</span>

        </div>

    </section>

    <!-- ================= STATS ================= -->

    <section class="stats">

        <div class="stat-card">
            <h4>🔥 Current Streak</h4>
            <h2><%= user.streak %> Days</h2>
        </div>

        <div class="stat-card">
            <h4>🏋 Total Workouts</h4>
            <h2>25</h2>
        </div>

        <div class="stat-card">
            <h4>🔥 Calories Burned</h4>
            <h2>12,500</h2>
        </div>

        <div class="stat-card">
            <h4>🏆 Challenge Points</h4>
            <h2><%= user.points %></h2>
        </div>

    </section>

    <!-- ================= MAIN CONTENT ================= -->

    <div class="dashboard-grid">

        <!-- LEFT -->

        <div class="left-panel">

            <!-- Active Challenge -->

            <div class="card">

                <h2>🏆 Active Challenge</h2>

                <h3>30-Day Push-up Challenge</h3>

                <p>Progress</p>

                <div class="progress">

                    <div class="progress-fill challenge-fill"></div>

                </div>

                <p>20 / 30 Days Completed</p>

                <p><strong>Current Rank:</strong> #12</p>

            </div>

            <!-- Recent Workouts -->

            <div class="card">

                <h2>🏋 Recent Workouts</h2>

                <ul class="activity">

                    <li>
                        <strong>Chest Workout</strong>
                        <span>Yesterday</span>
                    </li>

                    <li>
                        <strong>Leg Day</strong>
                        <span>2 Days Ago</span>
                    </li>

                    <li>
                        <strong>Morning Run</strong>
                        <span>3 Days Ago</span>
                    </li>

                </ul>

            </div>

            <!-- Achievements -->

            <div class="card">

                <h2>🥇 Achievements</h2>

                <div class="badges">

                    <span>🔥 7 Day Streak</span>

                    <span>🏆 Top 20</span>

                    <span>💯 100 Workouts</span>

                    <span>⭐ Challenge Winner</span>

                </div>

            </div>

        </div>

        <!-- RIGHT -->

        <div class="right-panel">

            <!-- User Profile -->

            <div class="card">

                <h2>👤 My Profile</h2>

                <p><strong>Name:</strong> <%= user.name %></p>

                <p><strong>Email:</strong> <%= user.email %></p>

                <p><strong>Age:</strong> <%= user.age %></p>

                <p><strong>Height:</strong> <%= user.height %> cm</p>

                <p><strong>Weight:</strong> <%= user.weight %> kg</p>

            </div>

            <!-- Leaderboard -->

            <div class="card">

                <h2>🏅 Leaderboard</h2>

                <ol>

                    <li>Rahul — 980 pts</li>

                    <li>Priya — 940 pts</li>

                    <li>Ashish — 890 pts</li>

                </ol>

                <a href="/leaderboard" class="btn">
                    View Full Leaderboard
                </a>

            </div>

            <!-- Quick Actions -->

            <div class="card">

                <h2>⚡ Quick Actions</h2>

                <div class="quick-actions">

                    <a href="/workouts" class="action-btn">
                        🏋 Log Workout
                    </a>

                    <a href="/challenges" class="action-btn">
                        🏆 Challenges
                    </a>

                    <a href="/photos" class="action-btn">
                        📷 Progress Photos
                    </a>

                    <a href="/community" class="action-btn">
                        👥 Community
                    </a>

                    <a href="/profile" class="action-btn">
                        👤 My Profile
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

<footer>

    <p>© 2026 Fitness Challenge Community</p>

</footer>

</body>
</html>