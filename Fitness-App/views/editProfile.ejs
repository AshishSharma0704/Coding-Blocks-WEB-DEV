<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile | Fitness Challenge Community</title>
    <link rel="stylesheet" href="/css/profile.css">
    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/updateWorkout.css">
    
</head>

<body>

    <%- include("partials/navbar") %>

    <div class="container">

        <div class="title">
            <h1>Edit Profile</h1>
            <p>Update your personal information and fitness goals.</p>
        </div>

        <div class="card">

            <form action="/profile/edit" method="POST">

                <!-- Name -->

                <div class="form-group">
                    <label>Full Name</label>

                    <input
                        type="text"
                        name="name"
                        value="<%= user.name %>"
                        required
                    >
                </div>

                <!-- Email -->

                <div class="form-group">
                    <label>Email Address</label>

                    <input
                        type="email"
                        value="<%= user.email %>"
                        readonly
                    >
                </div>

                <!-- Age -->

                <div class="form-group">
                    <label>Age</label>

                    <input
                        type="number"
                        name="age"
                        min="10"
                        max="100"
                        value="<%= user.age %>"
                    >
                </div>

                <!-- Height -->

                <div class="form-group">
                    <label>Height (cm)</label>

                    <input
                        type="number"
                        name="height"
                        min="50"
                        max="300"
                        value="<%= user.height %>"
                    >
                </div>

                <!-- Weight -->

                <div class="form-group">
                    <label>Weight (kg)</label>

                    <input
                        type="number"
                        name="weight"
                        min="20"
                        max="300"
                        step="0.1"
                        value="<%= user.weight %>"
                    >
                </div>

                <!-- Goal -->

                <div class="form-group">

                    <label>Fitness Goal</label>

                    <select name="goal">

                        <option value="Weight Loss"
                            <%= user.goal === "Weight Loss" ? "selected" : "" %>>
                            Weight Loss
                        </option>

                        <option value="Muscle Gain"
                            <%= user.goal === "Muscle Gain" ? "selected" : "" %>>
                            Muscle Gain
                        </option>

                        <option value="Maintain Fitness"
                            <%= user.goal === "Maintain Fitness" ? "selected" : "" %>>
                            Maintain Fitness
                        </option>

                        <option value="Endurance"
                            <%= user.goal === "Endurance" ? "selected" : "" %>>
                            Endurance
                        </option>

                        <option value="General Health"
                            <%= user.goal === "General Health" ? "selected" : "" %>>
                            General Health
                        </option>

                    </select>

                </div>

                <!-- Bio -->

                <div class="form-group">

                    <label>Bio</label>

                    <textarea
                        name="bio"
                        rows="5"
                        placeholder="Tell us about your fitness journey..."
                    ><%= user.bio %></textarea>

                </div>

                <!-- Buttons -->

                <div class="button-group">

                    <button type="submit" class="btn secondary">
                        Save Changes
                    </button>

                    <button href="/profile" class="btn">
                        Cancel
                    </button>

                </div>

            </form>

        </div>

    </div>

</body>
</html>
